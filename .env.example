# unified-llm Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI (optional - for GPT models)
OPENAI_API_KEY=

# Anthropic (optional - for Claude models via direct API)
ANTHROPIC_API_KEY=

# Google Gemini (optional - for Gemini models)
GEMINI_API_KEY=

# GLM Coding Plan / z.ai (optional - for GLM subscription)
ZAI_API_KEY=
